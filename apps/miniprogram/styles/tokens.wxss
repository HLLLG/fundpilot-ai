/**
 * 好基灵 FundPilot AI · 小程序设计系统 token
 * Requirements: 1.1（品牌色/背景/描边/涨跌语义色）、1.2（圆角/间距/阴影）、1.3（字体栈）
 *
 * 用法：在 app.wxss 中 `@import "styles/tokens.wxss";`，token 挂载在 page 根作用域，
 * 全局页面与组件均可通过 var(--token) 引用。涨跌遵循 A 股「红涨绿跌」语义。
 */

page {
  /* ── 品牌色 ───────────────────────────────── */
  --brand: #2356e0;        /* 深海蓝 · 主色 */
  --brand-strong: #173fb0; /* 主色加深（渐变/按下态） */
  --brand-soft: #e8eefc;   /* 主色浅底（标签/选中底） */
  --accent: #cf9b3e;       /* 暖金 · 强调色 */
  --accent-soft: #faf1dc;  /* 强调色浅底 */

  /* ── 背景与描边 ───────────────────────────── */
  --bg: #f3f6fc;           /* 页面背景 */
  --surface: #ffffff;      /* 卡片/面板背景 */
  --surface-muted: #f7f9fd;/* 次级面板背景 */
  --line: #e2e8f0;         /* 描边/分隔线 */
  --line-strong: #cbd5e1;  /* 强描边 */

  /* ── 文本色 ───────────────────────────────── */
  --text: #0f172a;         /* 主文本 */
  --text-secondary: #475569;/* 次文本 */
  --text-muted: #94a3b8;   /* 弱文本/占位 */
  --text-inverse: #ffffff; /* 反色文本（深底上） */

  /* ── 涨跌语义色（红涨绿跌） ──────────────── */
  --up: #e5484d;           /* 涨 · 红 */
  --up-soft: #fdecec;      /* 涨浅底 */
  --down: #2bae66;         /* 跌 · 绿 */
  --down-soft: #e6f6ee;    /* 跌浅底 */
  --neutral: #64748b;      /* 零/中性 */

  /* ── 状态色 ───────────────────────────────── */
  --warning: #d97706;      /* 告警 */
  --warning-soft: #fef3e2;
  --danger: #dc2626;       /* 错误 */
  --danger-soft: #fdecec;
  --success: #16a34a;      /* 成功 */

  /* ── 圆角 ─────────────────────────────────── */
  --radius-xs: 8rpx;
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-pill: 999rpx;   /* 胶囊/徽标 */

  /* ── 间距 ─────────────────────────────────── */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;
  --space-2xl: 64rpx;

  /* ── 阴影 ─────────────────────────────────── */
  --shadow-sm: 0 2rpx 8rpx rgba(15, 23, 42, 0.04);
  --shadow-md: 0 6rpx 20rpx rgba(15, 23, 42, 0.08);
  --shadow-lg: 0 12rpx 32rpx rgba(15, 23, 42, 0.12);
  --shadow-brand: 0 8rpx 24rpx rgba(35, 86, 224, 0.24);

  /* ── 字号 ─────────────────────────────────── */
  --font-xs: 22rpx;
  --font-sm: 24rpx;
  --font-base: 28rpx;
  --font-md: 30rpx;
  --font-lg: 34rpx;
  --font-xl: 40rpx;
  --font-2xl: 48rpx;

  /* ── 字体栈（小程序受支持字体，A6） ──────────
   * 不依赖 Web 的 Sora/PingFang 自定义字体；采用系统默认中文/英文字体栈，
   * 数字使用等宽倾向的系统字体以保持金额/收益对齐清晰可读（Req 1.3）。 */
  --font-family-base: -apple-system, BlinkMacSystemFont, "Helvetica Neue",
    "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "WenQuanYi Micro Hei",
    sans-serif;
  --font-family-number: "DIN Alternate", "Helvetica Neue", "SF Pro Display",
    "PingFang SC", system-ui, sans-serif;
}
