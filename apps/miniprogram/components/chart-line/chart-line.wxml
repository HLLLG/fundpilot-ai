<!-- components/chart-line/chart-line.wxml -->
<!-- 折线/分时图：包裹 ec-canvas，高度由 height prop 控制。Requirements: 8.2 -->
<view class="chart-line__container" style="height: {{height}};">
  <ec-canvas
    id="chart-line-ec"
    canvas-id="{{canvasId}}"
    ec="{{ec}}"
    class="chart-line__canvas"
  ></ec-canvas>
</view>
