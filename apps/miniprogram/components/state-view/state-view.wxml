<!-- components/state-view/state-view.wxml -->
<!-- 三态：loading / error（带重试）/ empty / content(slot)。Req 1.5, 4.1, 4.2 -->

<view wx:if="{{phase === 'loading'}}" class="sv sv--loading">
  <view class="sv__spinner"></view>
  <text class="sv__text">{{loadingText}}</text>
</view>

<view wx:elif="{{phase === 'error'}}" class="sv sv--error">
  <view class="sv__icon sv__icon--error">!</view>
  <text class="sv__text">{{errorMessage}}</text>
  <view class="btn btn-secondary btn--sm sv__retry" hover-class="btn--press" bindtap="onRetryTap">
    {{retryText}}
  </view>
</view>

<view wx:elif="{{phase === 'empty'}}" class="sv sv--empty">
  <view class="sv__icon sv__icon--empty">∅</view>
  <text class="sv__text">{{emptyText}}</text>
  <!-- 空态自定义操作入口（如「录入持仓」「关联邮箱」）通过具名插槽提供 -->
  <slot name="empty-actions"></slot>
</view>

<slot wx:else></slot>
