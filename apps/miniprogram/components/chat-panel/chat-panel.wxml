<!-- components/chat-panel/chat-panel.wxml -->
<!-- 非流式追问对话面板（Req 14, design.md chat-panel）。
     历史消息通过 GET /reports/{id}/chat 加载，
     发送走 POST .../chat/sync，assistant 回答用 md-view 渲染。
     失败态提供重试按钮（Req 14.5）。 -->

<view class="chat-panel">

  <!-- ── 历史加载态 ─────────────────────────────────── -->
  <state-view
    loading="{{historyLoading}}"
    error="{{historyError}}"
    empty="{{!historyLoading && !historyError && chatList.length === 0}}"
    emptyText="暂无对话记录，发送消息开始追问"
    bind:retry="onRetryHistory"
  >
    <!-- 对话气泡列表（scroll-view 支持滚动到底部） -->
    <scroll-view
      class="chat-panel__scroll"
      scroll-y
      scroll-into-view="{{scrollAnchor}}"
      enhanced
    >
      <view class="chat-panel__messages">
        <block wx:for="{{chatList}}" wx:key="index">
          <!-- 用户消息（右对齐） -->
          <view wx:if="{{item.role === 'user'}}" class="chat-bubble chat-bubble--user">
            <view class="chat-bubble__content chat-bubble__content--user">
              <text class="chat-bubble__text">{{item.content}}</text>
            </view>
          </view>

          <!-- Assistant 消息（左对齐，md-view 渲染） -->
          <view wx:elif="{{item.role === 'assistant'}}" class="chat-bubble chat-bubble--assistant">
            <view class="chat-bubble__avatar">AI</view>
            <view class="chat-bubble__content chat-bubble__content--assistant">
              <md-view markdown="{{item.content}}" />
            </view>
          </view>
        </block>

        <!-- 发送中占位气泡 -->
        <view wx:if="{{sending}}" class="chat-bubble chat-bubble--assistant">
          <view class="chat-bubble__avatar">AI</view>
          <view class="chat-bubble__content chat-bubble__content--assistant chat-bubble__content--loading">
            <text class="chat-panel__typing">…</text>
          </view>
        </view>

        <!-- 滚动锚点 -->
        <view id="chat-bottom-anchor" class="chat-panel__anchor"></view>
      </view>
    </scroll-view>
  </state-view>

  <!-- ── 发送错误提示 + 重试（Req 14.5） ─────────────── -->
  <view wx:if="{{sendError}}" class="chat-panel__error-bar">
    <text class="chat-panel__error-text">{{sendError}}</text>
    <view class="btn btn-secondary btn--sm chat-panel__retry-btn" bindtap="onRetry">
      重试
    </view>
  </view>

  <!-- ── 输入区：模式切换 + 文本框 + 发送按钮 ─────── -->
  <view class="chat-panel__input-area">
    <!-- 快速/深度模式切换 -->
    <view class="chat-panel__mode-bar">
      <view
        class="chat-panel__mode-btn {{chatMode === 'fast' ? 'chat-panel__mode-btn--active' : ''}}"
        data-mode="fast"
        bindtap="onModeChange"
      >快速</view>
      <view
        class="chat-panel__mode-btn {{chatMode === 'deep' ? 'chat-panel__mode-btn--active' : ''}}"
        data-mode="deep"
        bindtap="onModeChange"
      >深度</view>
    </view>

    <view class="chat-panel__input-row">
      <textarea
        class="chat-panel__textarea"
        placeholder="输入追问内容…"
        value="{{inputValue}}"
        bindinput="onInput"
        disabled="{{sending || loading}}"
        auto-height
        maxlength="500"
        confirm-type="send"
        bindconfirm="onSubmit"
      />
      <view
        class="chat-panel__send-btn {{(sending || loading || !inputValue) ? 'chat-panel__send-btn--disabled' : ''}}"
        bindtap="onSubmit"
      >
        <text>发送</text>
      </view>
    </view>
  </view>

</view>
