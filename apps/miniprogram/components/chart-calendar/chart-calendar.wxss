/* components/chart-calendar/chart-calendar.wxss */
/* 盈亏日历网格布局与涨跌配色。Requirements: 9.4, 9.5 */
/* 依赖 styles/tokens.wxss 的 CSS 变量（--up/--down/--neutral/--up-soft/--down-soft 等）。 */

/* ── 外层容器 ─────────────────────────────────────── */
.cal {
  width: 100%;
  box-sizing: border-box;
}

/* ── 月份导航条 ──────────────────────────────────── */
.cal__nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-sm) var(--space-md);
  margin-bottom: var(--space-xs);
}

.cal__nav-title {
  font-size: var(--font-base);
  font-weight: 700;
  color: var(--text);
  letter-spacing: 0.02em;
}

.cal__nav-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-pill);
  background: var(--surface-muted);
  border: 1rpx solid var(--line);
}

.cal__nav-btn:active {
  opacity: 0.7;
}

.cal__nav-icon {
  font-size: var(--font-xl);
  color: var(--text-secondary);
  line-height: 1;
}

/* ── 7 列网格（表头 + 日期格共用） ──────────────── */
.cal__grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 4rpx;
  padding: 0 var(--space-xs);
}

/* ── 星期表头行 ─────────────────────────────────── */
.cal__grid--header {
  margin-bottom: 4rpx;
}

.cal__header-cell {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 48rpx;
}

.cal__header-text {
  font-size: var(--font-xs);
  font-weight: 600;
  color: var(--text-muted);
}

/* ── 日期格基础 ─────────────────────────────────── */
.cal__cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  min-height: 88rpx;
  border-radius: var(--radius-sm);
  padding: 8rpx 4rpx 6rpx;
  box-sizing: border-box;
  overflow: hidden;
}

/* 空白占位格（padding 行用） */
.cal__cell--empty {
  background: transparent;
  min-height: 88rpx;
}

/* ── 非交易日：浅灰底，不展示盈亏数字 ─────────── */
.cal__cell--non-trading {
  background: var(--surface-muted);
  border: 1rpx solid var(--line);
}

/* colorClass=placeholder（来自 mapCalendarColors）同非交易日样式 */
.cal__cell--placeholder {
  background: var(--surface-muted);
  border: 1rpx solid var(--line);
}

/* ── 交易日涨色（正盈利，--up 红） ──────────────── */
.cal__cell--trading.cal__cell--up {
  background: var(--up-soft);
  border: 1rpx solid var(--up);
}

/* ── 交易日跌色（负盈利，--down 绿） ────────────── */
.cal__cell--trading.cal__cell--down {
  background: var(--down-soft);
  border: 1rpx solid var(--down);
}

/* ── 交易日中性（零盈亏，--neutral） ────────────── */
.cal__cell--trading.cal__cell--neutral {
  background: var(--surface);
  border: 1rpx solid var(--line-strong);
}

/* ── 日期数字 ─────────────────────────────────── */
.cal__date-num {
  font-size: var(--font-xs);
  font-weight: 600;
  color: var(--text-secondary);
  line-height: 1.2;
  margin-bottom: 4rpx;
}

/* ── 盈亏数值容器 ───────────────────────────────── */
.cal__profit {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* num-text 字号在日历格内缩小 */
.cal__profit num-text {
  font-size: var(--font-xs);
}

/* 空盈亏占位 */
.cal__profit--empty .cal__profit-placeholder {
  font-size: var(--font-xs);
  color: var(--text-muted);
}
