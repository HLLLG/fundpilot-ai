<!-- components/chart-calendar/chart-calendar.wxml -->
<!-- 盈亏日历：WXML 7 列网格自绘，复用 num-text 做涨跌着色。Requirements: 9.4, 9.5 -->

<view class="cal">
  <!-- ── 月份导航条 ─────────────────────────────── -->
  <view class="cal__nav">
    <view class="cal__nav-btn" bindtap="onPrevMonth">
      <text class="cal__nav-icon">‹</text>
    </view>
    <text class="cal__nav-title">{{titleLabel}}</text>
    <view class="cal__nav-btn" bindtap="onNextMonth">
      <text class="cal__nav-icon">›</text>
    </view>
  </view>

  <!-- ── 星期表头（一二三四五六日，Mon-Sun） ─────── -->
  <view class="cal__grid cal__grid--header">
    <view
      wx:for="{{weekHeaders}}"
      wx:key="index"
      class="cal__header-cell"
    >
      <text class="cal__header-text">{{item}}</text>
    </view>
  </view>

  <!-- ── 日期格网格 ─────────────────────────────── -->
  <view class="cal__grid">
    <view
      wx:for="{{gridCells}}"
      wx:key="key"
      class="cal__cell {{item.isEmpty ? 'cal__cell--empty' : ''}} {{!item.isEmpty && !item.isTrading ? 'cal__cell--non-trading' : ''}} {{!item.isEmpty && item.isTrading ? 'cal__cell--trading cal__cell--' + item.colorClass : ''}}"
    >
      <!-- 有效日期格（非占位空白格）-->
      <block wx:if="{{!item.isEmpty}}">
        <!-- 日期数字 -->
        <text class="cal__date-num">{{item.dateNum}}</text>

        <!-- 交易日：用 num-text 展示 daily_profit，着色来自 colorClass -->
        <view wx:if="{{item.isTrading && item.profitValue !== null}}" class="cal__profit">
          <num-text
            value="{{item.profitValue}}"
            kind="money"
            signed="{{true}}"
            digits="{{0}}"
          />
        </view>

        <!-- 交易日但无盈亏数据：展示中性占位 -->
        <view wx:elif="{{item.isTrading}}" class="cal__profit cal__profit--empty">
          <text class="cal__profit-placeholder">—</text>
        </view>

        <!-- 非交易日：不展示盈亏数字，仅灰色底 -->
        <!-- （colorClass=placeholder，已由 CSS class 处理） -->
      </block>
    </view>
  </view>
</view>
