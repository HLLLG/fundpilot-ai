/* components/num-text/num-text.wxss */
/* tone → 红涨绿跌配色映射，复用 styles/tokens.wxss 语义色。Req 1.6 */

.num-text {
  /* 等宽倾向数字字体，金额/收益纵向对齐（与 shared.wxss .u-num 一致）。 */
  font-family: var(--font-family-number);
  font-variant-numeric: tabular-nums;
}

/* 涨 · 红 */
.num-text--up {
  color: var(--up);
}

/* 跌 · 绿 */
.num-text--down {
  color: var(--down);
}

/* 零 / 中性 */
.num-text--flat {
  color: var(--neutral);
}

/* 空值占位用弱文本色 */
.num-text--placeholder {
  color: var(--text-muted);
}
