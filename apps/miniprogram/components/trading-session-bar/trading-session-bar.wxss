/* components/trading-session-bar/trading-session-bar.wxss */
/* 依赖全局 styles/tokens.wxss 与 styles/shared.wxss（.badge/.u-num 等通用类）。 */

.tsb {
  display: block;
}

.tsb__bar {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--space-sm);
  padding: var(--space-sm) var(--space-md);
  background: var(--surface);
  border: 1rpx solid var(--line);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  box-sizing: border-box;
}

.tsb__icon {
  font-size: var(--font-sm);
  line-height: 1;
}

/* 时段语义徽标着色（复用 shared.wxss 的 .badge 基类 + 本地变体） */
.tsb__badge {
  font-size: var(--font-xs);
}

.tsb__badge--active {
  background: var(--brand-soft);
  color: var(--brand);
}

.tsb__badge--accent {
  background: var(--accent-soft);
  color: var(--accent);
}

.tsb__badge--muted {
  background: var(--surface-muted);
  color: var(--text-secondary);
}

.tsb__date {
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.tsb__close {
  padding: 2rpx var(--space-sm);
  border-radius: var(--radius-pill);
  background: var(--surface-muted);
  color: var(--text-secondary);
  font-size: var(--font-xs);
}

/* ── 加载态 ── */
.tsb__bar--skeleton {
  color: var(--text-muted);
}

.tsb__skeleton-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: var(--radius-pill);
  background: var(--line);
}

.tsb__skeleton-text {
  font-size: var(--font-sm);
  color: var(--text-muted);
}

/* ── 错误/降级态 ── */
.tsb__bar--error {
  color: var(--text-secondary);
}

.tsb__error-text {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--text-secondary);
}

.tsb__retry {
  margin-left: auto;
  font-size: var(--font-xs);
  color: var(--brand);
}
