/**
 * pages/history/history.wxss
 * 历史日报页样式（Req 20.1–20.3）。
 * 与 styles/tokens.wxss 设计 token 对齐（不重复定义 token 变量）。
 */

.history-page {
  min-height: 100vh;
  background: var(--bg, #f3f6fc);
  padding: 16rpx 24rpx 160rpx;
  box-sizing: border-box;
}

/* ── 顶部工具条 ──────────────────────────────────────── */
.history-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
}

.history-toolbar__title {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text, #1a2237);
}

.history-toolbar__count {
  font-size: 26rpx;
  color: var(--text-secondary, #6b7a9a);
}

.history-toolbar__actions {
  display: flex;
  gap: 12rpx;
}

/* ── 列表 ────────────────────────────────────────────── */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 16rpx;
}

.history-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
}

.history-item--selected {
  border: 2rpx solid var(--brand, #2356e0);
  background: rgba(35, 86, 224, 0.06);
}

.history-item__check {
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

.history-checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: var(--radius-sm, 8rpx);
  border: 2rpx solid var(--line, #e5eaf5);
  background: var(--surface, #fff);
  display: flex;
  align-items: center;
  justify-content: center;
}

.history-checkbox--on {
  background: var(--brand, #2356e0);
  border-color: var(--brand, #2356e0);
}

.history-checkbox__tick {
  color: #fff;
  font-size: 26rpx;
  line-height: 1;
}

.history-item__main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.history-item__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.history-item__title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text, #1a2237);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.history-item__risk {
  flex-shrink: 0;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: var(--surface-muted, #f1f5fb);
  color: var(--text-secondary, #6b7a9a);
}

.history-item__risk--high {
  background: rgba(229, 72, 77, 0.12);
  color: var(--down, #e5484d);
}

.history-item__risk--medium {
  background: rgba(207, 155, 62, 0.14);
  color: var(--accent, #cf9b3e);
}

.history-item__risk--low {
  background: rgba(35, 86, 224, 0.1);
  color: var(--brand, #2356e0);
}

.history-item__date {
  font-size: 24rpx;
  color: var(--text-secondary, #6b7a9a);
}

.history-item__arrow {
  flex-shrink: 0;
  font-size: 40rpx;
  color: var(--text-secondary, #6b7a9a);
  line-height: 1;
}

/* ── 批量删除浮条 ────────────────────────────────────── */
.history-batchbar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 32rpx;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx;
  background: var(--surface, #fff);
  border-radius: var(--radius-md, 16rpx);
  box-shadow: 0 8rpx 24rpx rgba(26, 34, 55, 0.16);
}

.history-batchbar__info {
  font-size: 26rpx;
  color: var(--text, #1a2237);
}

/* 危险操作按钮（批量删除）*/
.btn-danger {
  background: var(--down, #e5484d);
  color: #fff;
  border: none;
}

.btn-danger.btn--disabled {
  opacity: 0.6;
}

/* ── 详情弹层（Req 20.2）────────────────────────────── */
.history-detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.history-detail-sheet {
  width: 100%;
  background: var(--surface, #fff);
  border-radius: var(--radius-md, 20rpx) var(--radius-md, 20rpx) 0 0;
  padding: 28rpx 32rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  max-height: 80vh;
}

.history-detail__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid var(--line, #e5eaf5);
}

.history-detail__heading {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
  min-width: 0;
}

.history-detail__title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text, #1a2237);
}

.history-detail__date {
  font-size: 24rpx;
  color: var(--text-secondary, #6b7a9a);
}

.history-detail__close {
  flex-shrink: 0;
  font-size: 36rpx;
  color: var(--text-secondary, #6b7a9a);
  line-height: 1;
  padding: 4rpx 8rpx;
}

.history-detail__body {
  flex: 1;
  margin-top: 20rpx;
  max-height: 60vh;
}

.history-detail__empty {
  font-size: 26rpx;
  color: var(--text-secondary, #6b7a9a);
  text-align: center;
  padding: 40rpx 0;
}
