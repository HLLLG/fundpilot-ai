<view class="page">
  <view class="card">
    <text class="title">关联已有邮箱账号</text>
    <text class="subtitle">输入你在 Web 端注册的邮箱与密码，关联后即可在小程序看到相同持仓</text>

    <input
      class="field"
      type="text"
      placeholder="邮箱"
      value="{{account}}"
      bindinput="onAccountInput"
    />
    <input
      class="field"
      password="{{true}}"
      placeholder="密码"
      value="{{password}}"
      bindinput="onPasswordInput"
    />

    <button class="btn" loading="{{loading}}" bindtap="onLink">关联账号</button>
    <button class="btn-ghost" bindtap="onCancel">返回</button>
    <text class="error" wx:if="{{error}}">{{error}}</text>
  </view>
</view>
