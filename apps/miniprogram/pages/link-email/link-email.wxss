.page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #eff6ff 0%, #f8fafc 100%);
  padding: 48rpx;
}

.card {
  width: 100%;
  background: #fff;
  border-radius: 32rpx;
  padding: 64rpx 48rpx;
  box-shadow: 0 24rpx 60rpx rgba(15, 23, 42, 0.08);
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #0f172a;
  text-align: center;
}

.subtitle {
  display: block;
  margin-top: 16rpx;
  margin-bottom: 40rpx;
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.6;
  text-align: center;
}

.field {
  margin-top: 24rpx;
  padding: 24rpx 28rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 20rpx;
  font-size: 30rpx;
  color: #0f172a;
}

.btn {
  margin-top: 48rpx;
  background: linear-gradient(90deg, #2356e0, #173fb0);
  color: #fff;
  border-radius: 24rpx;
}

.btn-ghost {
  margin-top: 20rpx;
  background: transparent;
  color: #64748b;
  border-radius: 24rpx;
}

.error {
  display: block;
  margin-top: 24rpx;
  color: #dc2626;
  font-size: 26rpx;
  text-align: center;
}
