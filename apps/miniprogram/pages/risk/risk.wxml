<!-- pages/risk/risk.wxml -->
<!-- Risk_Profile_Page（风控画像与日报角色设定）
     Req 18.1–18.5：读取/编辑风控画像、预设联动、保存、日报角色设定。 -->

<scroll-view class="risk-page" scroll-y enhanced>

  <!-- ── 风控画像（Req 18.1, 18.2, 18.3, 18.4）─────────── -->
  <state-view
    loading="{{loading}}"
    error="{{error}}"
    bind:retry="onRetry"
  >
    <view class="card risk-section">
      <view class="risk-section__title">风控画像</view>

      <!-- 投资预设切换（分段控件，Req 18.3）-->
      <view class="form-col">
        <text class="form-label">投资预设</text>
        <view class="segmented">
          <view
            wx:for="{{presetOptions}}"
            wx:key="value"
            class="segmented__item {{presetIndex === index ? 'segmented__item--active' : ''}}"
            data-value="{{index}}"
            bindtap="onPresetChange"
          >{{item.label}}</view>
        </view>
        <text class="form-hint">切换预设会联动浮亏线、集中度、偏定投与拒绝追高。</text>
      </view>

      <!-- 浮亏线（Req 18.2）-->
      <view class="form-row">
        <text class="form-label">浮亏线（%）</text>
        <input
          class="form-input"
          type="digit"
          placeholder="如：10"
          value="{{form.max_drawdown_percent}}"
          bindinput="onMaxDrawdownInput"
        />
      </view>

      <!-- 单只集中度（Req 18.2）-->
      <view class="form-row">
        <text class="form-label">单只集中度（%）</text>
        <input
          class="form-input"
          type="digit"
          placeholder="如：30"
          value="{{form.concentration_limit_percent}}"
          bindinput="onConcentrationInput"
        />
      </view>

      <!-- 期望投入总额（Req 18.2）-->
      <view class="form-row">
        <text class="form-label">期望投入总额（元）</text>
        <input
          class="form-input"
          type="digit"
          placeholder="如：50000"
          value="{{form.expected_investment_amount}}"
          bindinput="onExpectedAmountInput"
        />
      </view>

      <!-- 偏定投（Req 18.2）-->
      <view class="form-row">
        <text class="form-label">偏定投</text>
        <switch
          checked="{{form.prefer_dca}}"
          bindchange="onPreferDcaChange"
          color="#2356e0"
        />
      </view>

      <!-- 拒绝追高（Req 18.2）-->
      <view class="form-row">
        <text class="form-label">拒绝追高</text>
        <switch
          checked="{{form.avoid_chasing}}"
          bindchange="onAvoidChasingChange"
          color="#2356e0"
        />
      </view>
    </view>

    <!-- 保存风控画像（Req 18.4）-->
    <view class="risk-actions">
      <view
        class="btn btn-primary btn--lg risk-actions__btn {{saving ? 'btn--disabled' : ''}}"
        bindtap="onSaveProfile"
      >{{saving ? '保存中…' : '保存风控画像'}}</view>
    </view>
  </state-view>

  <!-- ── 日报 AI 角色设定（Req 18.5）──────────────────── -->
  <view class="card risk-section">
    <view class="form-row form-row--between">
      <view class="risk-section__title">日报 AI 角色设定</view>
      <view
        class="btn btn-secondary btn--xs {{promptSaving ? 'btn--disabled' : ''}}"
        bindtap="onSavePrompt"
      >{{promptSaving ? '保存中…' : '保存'}}</view>
    </view>
    <text class="form-hint">自定义日报分析的 AI 角色与口吻（可选）。</text>
    <textarea
      class="form-textarea"
      placeholder="{{promptLoading ? '加载中…' : '输入日报 AI 角色提示词（可选）…'}}"
      value="{{rolePrompt}}"
      bindinput="onPromptInput"
      maxlength="1000"
      auto-height
    />
  </view>

  <!-- 底部留白 -->
  <view style="height: 40rpx;"></view>

</scroll-view>
