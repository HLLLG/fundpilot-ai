/**
 * pages/risk/risk.wxss
 * 风控画像与日报角色设定页样式（Req 18）。
 * 与 styles/tokens.wxss 设计 token 对齐（不重复定义 token 变量）。
 */

.risk-page {
  height: 100vh;
  background: var(--bg, #f3f6fc);
  box-sizing: border-box;
}

/* ── 区块 ────────────────────────────────────────────── */
.risk-section {
  margin: 16rpx 24rpx 0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.risk-section__title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text, #1a2237);
}

/* ── 表单行/列 ──────────────────────────────────────── */
.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.form-row--between {
  justify-content: space-between;
}

.form-col {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.form-label {
  font-size: 26rpx;
  color: var(--text-secondary, #6b7a9a);
  white-space: nowrap;
  flex-shrink: 0;
}

.form-hint {
  font-size: 22rpx;
  color: var(--text-secondary, #6b7a9a);
  line-height: 1.5;
}

.form-input {
  flex: 1;
  padding: 10rpx 20rpx;
  background: var(--surface-muted, #f1f5fb);
  border-radius: var(--radius-sm, 10rpx);
  border: 2rpx solid var(--line, #e5eaf5);
  font-size: 26rpx;
  color: var(--text, #1a2237);
  text-align: right;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 16rpx;
  background: var(--surface-muted, #f1f5fb);
  border-radius: var(--radius-sm, 10rpx);
  border: 2rpx solid var(--line, #e5eaf5);
  font-size: 26rpx;
  color: var(--text, #1a2237);
  box-sizing: border-box;
  line-height: 1.5;
}

/* ── 分段控件（预设切换）────────────────────────────── */
.segmented {
  display: flex;
  background: var(--surface-muted, #f1f5fb);
  border-radius: var(--radius-sm, 10rpx);
  overflow: hidden;
  border: 2rpx solid var(--line, #e5eaf5);
}

.segmented__item {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 26rpx;
  color: var(--text-secondary, #6b7a9a);
  line-height: 1.4;
}

.segmented__item--active {
  background: var(--brand, #2356e0);
  color: #fff;
  font-weight: 600;
}

/* ── 保存按钮 ────────────────────────────────────────── */
.risk-actions {
  margin: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.risk-actions__btn {
  width: 100%;
  text-align: center;
  font-size: 32rpx;
  padding: 24rpx;
  border-radius: var(--radius-md, 16rpx);
  font-weight: 600;
}

.btn--disabled {
  opacity: 0.6;
}
