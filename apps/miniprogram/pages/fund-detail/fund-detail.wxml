<!-- pages/fund-detail/fund-detail.wxml -->
<!-- 基金详情页。Requirements: 8.1（持仓字段）、8.2（板块分时图）、8.3（业绩对比）、8.4（历史净值分页）、8.5/8.6（首次购入日 + 持有天数重算） -->

<view class="page">
  <state-view
    loading="{{loading}}"
    error="{{error}}"
    empty="{{!detail && !loading && !error}}"
    empty-text="暂无详情"
    bind:retry="onRetry"
  >
    <!-- ── 基金标题 ─────────────────────────────────── -->
    <view wx:if="{{detail}}" class="card header-card">
      <view class="fund-title">
        <text class="fund-name">{{detail.holding.fund_name}}</text>
        <text class="fund-code">{{detail.holding.fund_code}}</text>
      </view>
      <view wx:if="{{detail.holding.sector_name}}" class="sector-badge">
        <text class="sector-text">{{detail.holding.sector_name}}</text>
      </view>
    </view>

    <!-- ── Req 8.1 持仓核心字段 ───────────────────── -->
    <view wx:if="{{detail}}" class="card metrics-card">
      <view class="metrics-grid">
        <!-- 持有金额 -->
        <view class="metric-item">
          <text class="metric-label">持有金额</text>
          <num-text
            class="metric-value"
            value="{{detail.holding.holding_amount}}"
            kind="money"
            signed="{{false}}"
          />
        </view>

        <!-- 持有收益 -->
        <view class="metric-item">
          <text class="metric-label">持有收益</text>
          <num-text
            class="metric-value"
            value="{{detail.holding.holding_return_percent}}"
            kind="percent"
          />
        </view>

        <!-- 持有份额 -->
        <view class="metric-item">
          <text class="metric-label">持有份额</text>
          <view class="metric-value-plain">
            <text>{{detail.holding_shares != null ? detail.holding_shares : '—'}}</text>
            <text class="metric-unit">份</text>
          </view>
        </view>

        <!-- 成本 -->
        <view class="metric-item">
          <text class="metric-label">持仓成本</text>
          <num-text
            class="metric-value"
            value="{{detail.holding_cost}}"
            kind="money"
            signed="{{false}}"
          />
        </view>

        <!-- 持有天数 -->
        <view class="metric-item">
          <text class="metric-label">持有天数</text>
          <view class="metric-value-plain">
            <text>{{detail.holding_days != null ? detail.holding_days : '—'}}</text>
            <text class="metric-unit">天</text>
          </view>
        </view>

        <!-- 最新净值 + 净值日期 -->
        <view class="metric-item">
          <text class="metric-label">最新净值</text>
          <view class="metric-value-nav">
            <text class="metric-nav-value">{{detail.latest_nav != null ? detail.latest_nav : '—'}}</text>
            <text class="metric-nav-date">{{detail.nav_date || ''}}</text>
          </view>
        </view>
      </view>

      <!-- Req 8.5/8.6：首次购入日选择 + 持有天数重算 -->
      <view class="purchase-date-row">
        <view class="purchase-date-label-wrap">
          <text class="metric-label">首次购入日</text>
          <view wx:if="{{purchaseDateSaving}}" class="purchase-date-saving">
            <text class="purchase-date-saving-text">保存中…</text>
          </view>
        </view>
        <picker
          mode="date"
          value="{{detail.holding.first_purchase_date || ''}}"
          bindchange="onFirstPurchaseDateChange"
          disabled="{{purchaseDateSaving}}"
        >
          <view class="purchase-date-picker-inner">
            <text class="purchase-date-value">
              {{detail.holding.first_purchase_date || '未设置'}}
            </text>
            <text class="purchase-date-edit">修改</text>
          </view>
        </picker>
      </view>
    </view>

    <!-- ── 板块分时图（Req 8.2） ──────────────────── -->
    <view wx:if="{{detail}}" class="card chart-card">
      <view class="chart-header">
        <text class="chart-title">板块分时</text>
        <text class="chart-sector">{{detail.holding.sector_name || ''}}</text>
      </view>

      <!-- 分时图加载中 -->
      <view wx:if="{{chartLoading}}" class="chart-placeholder chart-placeholder--loading">
        <text class="chart-hint">图表加载中…</text>
      </view>

      <!-- 分时图加载失败 -->
      <view wx:elif="{{chartError && !hasIntraday}}" class="chart-placeholder chart-placeholder--error">
        <text class="chart-hint chart-hint--error">{{chartError}}</text>
        <view class="btn btn-secondary btn--sm" bindtap="onChartRetry">重试</view>
      </view>

      <!-- 无板块信息 -->
      <view wx:elif="{{!chartLoading && !hasIntraday && !chartError}}" class="chart-placeholder chart-placeholder--empty">
        <text class="chart-hint">暂无分时数据</text>
      </view>

      <!-- 图表渲染 -->
      <chart-line
        wx:elif="{{hasIntraday}}"
        option="{{intradayOption}}"
        canvas-id="intraday-chart"
        height="360rpx"
      />
    </view>

    <!-- ── 业绩对比（Req 8.3） ───────────────────── -->
    <view wx:if="{{detail}}" class="card perf-card">
      <view class="chart-header">
        <text class="chart-title">业绩走势</text>
      </view>

      <!-- 区间 Tab 选择器 -->
      <view class="perf-range-tabs">
        <view
          wx:for="{{perfRanges}}"
          wx:key="label"
          class="perf-range-tab {{index === perfRangeIndex ? 'perf-range-tab--active' : ''}}"
          data-index="{{index}}"
          bindtap="onPerfRangeTap"
        >
          <text>{{item.label}}</text>
        </view>
      </view>

      <!-- 业绩对比图加载中 -->
      <view wx:if="{{perfLoading}}" class="chart-placeholder chart-placeholder--loading">
        <text class="chart-hint">加载中…</text>
      </view>

      <!-- 业绩对比图加载失败 -->
      <view wx:elif="{{perfError && !perfOption}}" class="chart-placeholder chart-placeholder--error">
        <text class="chart-hint chart-hint--error">{{perfError}}</text>
        <view class="btn btn-secondary btn--sm" bindtap="onPerfRetry">重试</view>
      </view>

      <!-- 业绩对比折线图 -->
      <chart-line
        wx:elif="{{perfOption}}"
        option="{{perfOption}}"
        canvas-id="perf-chart"
        height="400rpx"
      />

      <!-- 说明：本基金 vs 沪深300 -->
      <view wx:if="{{perfOption && !perfLoading}}" class="perf-legend">
        <view class="perf-legend-item">
          <view class="perf-legend-dot perf-legend-dot--fund"></view>
          <text class="perf-legend-label">本基金</text>
        </view>
        <view class="perf-legend-item">
          <view class="perf-legend-dot perf-legend-dot--index"></view>
          <text class="perf-legend-label">沪深300</text>
        </view>
      </view>
    </view>

    <!-- ── 历史净值（Req 8.4） ───────────────────── -->
    <view wx:if="{{detail}}" class="card nav-history-card">
      <view class="chart-header">
        <text class="chart-title">历史净值</text>
      </view>

      <!-- 净值首次加载中 -->
      <view wx:if="{{navLoading}}" class="chart-placeholder chart-placeholder--loading">
        <text class="chart-hint">加载中…</text>
      </view>

      <!-- 净值加载失败（首次） -->
      <view wx:elif="{{navError && navList.length === 0}}" class="chart-placeholder chart-placeholder--error">
        <text class="chart-hint chart-hint--error">{{navError}}</text>
        <view class="btn btn-secondary btn--sm" bindtap="onNavRetry">重试</view>
      </view>

      <!-- 净值列表 -->
      <view wx:elif="{{navList.length > 0}}" class="nav-list">
        <!-- 表头 -->
        <view class="nav-list-header">
          <text class="nav-col nav-col--date">日期</text>
          <text class="nav-col nav-col--nav">单位净值</text>
          <text class="nav-col nav-col--change">日涨跌幅</text>
        </view>

        <!-- 净值行 -->
        <view
          wx:for="{{navList}}"
          wx:key="date"
          class="nav-list-row"
        >
          <text class="nav-col nav-col--date">{{item.date}}</text>
          <text class="nav-col nav-col--nav">{{item.nav_value != null ? item.nav_value : '—'}}</text>
          <num-text
            class="nav-col nav-col--change"
            value="{{item.change_percent}}"
            kind="percent"
          />
        </view>

        <!-- 加载更多 / 加载中 / 已到底 -->
        <view class="nav-load-more">
          <view wx:if="{{navLoadingMore}}" class="nav-load-more-hint">
            <text class="chart-hint">加载中…</text>
          </view>
          <view
            wx:elif="{{navHasMore}}"
            class="btn btn-secondary nav-load-more-btn"
            bindtap="onNavLoadMore"
          >
            <text>加载更多</text>
          </view>
          <view wx:else class="nav-load-more-hint">
            <text class="chart-hint">已加载全部</text>
          </view>
        </view>
      </view>

      <!-- 净值为空 -->
      <view wx:elif="{{!navLoading && navList.length === 0 && !navError}}" class="chart-placeholder chart-placeholder--empty">
        <text class="chart-hint">暂无净值数据</text>
      </view>
    </view>
  </state-view>
</view>
