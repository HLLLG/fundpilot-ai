.page { padding: 24rpx; }
.card { background: #fff; border-radius: 24rpx; padding: 32rpx; }
.name { display: block; font-size: 36rpx; font-weight: 800; color: #0f172a; }
.code { display: block; margin-top: 8rpx; color: #94a3b8; font-size: 26rpx; }
.grid { margin-top: 32rpx; display: grid; grid-template-columns: 1fr 1fr; gap: 24rpx; }
.item { background: #f8fafc; border-radius: 16rpx; padding: 20rpx; }
.label { display: block; font-size: 22rpx; color: #64748b; }
.value { display: block; margin-top: 8rpx; font-size: 30rpx; font-weight: 700; color: #0f172a; }
.hint, .error { text-align: center; padding: 48rpx; color: #64748b; }
.error { color: #dc2626; }
