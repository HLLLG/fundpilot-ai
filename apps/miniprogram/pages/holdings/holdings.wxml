<!-- pages/holdings/holdings.wxml -->
<!-- Holdings_Board 持仓看板页 -->
<!-- Requirements: 5.1, 5.2, 5.3, 5.4, 5.5, 5.6, 5.7 -->
<!--
  使用的设计系统类（styles/shared.wxss + styles/tokens.wxss）：
  .card / .btn / .btn-primary / .btn-secondary / .btn--sm / .badge
  使用的组件：state-view、num-text
-->

<view class="u-page holdings-page">

  <!-- 组合摘要卡片（有 summary 时展示） -->
  <view class="card summary-card" wx:if="{{summary}}">
    <view class="summary-row">
      <view class="summary-item">
        <text class="summary-label">总资产（元）</text>
        <num-text class="summary-value" value="{{summary.total_assets}}" kind="money" />
      </view>
      <view class="summary-item summary-item--right">
        <text class="summary-label">当日收益（元）</text>
        <num-text class="summary-value" value="{{summary.daily_profit}}" kind="money" signed="{{true}}" />
      </view>
    </view>
    <view class="summary-row summary-row--sub" wx:if="{{summary.daily_return_percent != null}}">
      <num-text value="{{summary.daily_return_percent}}" kind="percent" />
    </view>
    <!-- refreshed_at（Req 5.7） -->
    <view class="refreshed-at" wx:if="{{refreshedAt}}">
      <text class="refreshed-at__text">更新于 {{refreshedAt}}</text>
      <text class="refreshed-at__stale" wx:if="{{stale}}">（数据刷新中…）</text>
    </view>
  </view>

  <!-- 工具栏 -->
  <view class="holdings-toolbar">
    <view
      class="btn btn-secondary btn--sm {{refreshing ? 'btn--disabled' : ''}}"
      hover-class="btn--press"
      bindtap="onRefreshSectors"
    >
      <text wx:if="{{refreshing}}">刷新中…</text>
      <text wx:else>刷新板块</text>
    </view>
    <!-- refreshed_at（无 summary 时也展示，Req 5.7） -->
    <text class="refreshed-at__text refreshed-at__text--toolbar" wx:if="{{!summary && refreshedAt}}">
      更新于 {{refreshedAt}}
    </text>
  </view>

  <!-- 三态包裹：loading / error / empty / 内容 -->
  <state-view
    loading="{{loading}}"
    error="{{error}}"
    empty="{{isEmpty}}"
    empty-text="暂无持仓记录"
    bind:retry="onRetry"
  >
    <!-- 空态操作入口（Req 5.6） -->
    <view slot="empty-actions" class="empty-actions">
      <view
        class="btn btn-primary btn--block empty-actions__btn"
        hover-class="btn--press"
        bindtap="onGoOcrImport"
      >
        截图录入持仓
      </view>
      <view
        class="btn btn-secondary btn--block empty-actions__btn"
        hover-class="btn--press"
        bindtap="onGoLink"
      >
        关联已有邮箱账号
      </view>
    </view>

    <!-- 持仓列表（Req 5.3：名称/持有金额/持有收益率/当日收益/板块涨跌） -->
    <view
      class="card holding-card"
      wx:for="{{holdings}}"
      wx:key="fund_code"
      data-index="{{index}}"
      bindtap="onOpenDetail"
    >
      <!-- 第一行：基金名称 + 基金代码 -->
      <view class="holding-row holding-row--header">
        <text class="holding-name">{{item.fund_name || item.fund_code}}</text>
        <text class="holding-code badge badge--muted">{{item.fund_code}}</text>
      </view>

      <!-- 第二行：持有金额 + 持有收益率 -->
      <view class="holding-row">
        <view class="holding-field">
          <text class="holding-field__label">持有金额</text>
          <num-text value="{{item.holding_amount}}" kind="money" />
        </view>
        <view class="holding-field holding-field--right">
          <text class="holding-field__label">持有收益率</text>
          <num-text
            value="{{item.holding_return_percent != null ? item.holding_return_percent : item.return_percent}}"
            kind="percent"
          />
        </view>
      </view>

      <!-- 第三行：当日收益 + 当日涨跌幅 -->
      <view class="holding-row">
        <view class="holding-field">
          <text class="holding-field__label">当日收益</text>
          <num-text value="{{item.daily_profit}}" kind="money" signed="{{true}}" />
        </view>
        <view class="holding-field holding-field--right">
          <text class="holding-field__label">当日涨跌</text>
          <num-text value="{{item.daily_return_percent}}" kind="percent" />
        </view>
      </view>

      <!-- 第四行：板块名称 + 板块涨跌（Req 5.3） -->
      <view class="holding-row holding-row--sector" wx:if="{{item.sector_name}}">
        <text class="badge badge--muted holding-sector-name">{{item.sector_name}}</text>
        <num-text
          wx:if="{{item.sector_return_percent != null}}"
          value="{{item.sector_return_percent}}"
          kind="percent"
        />
        <text wx:else class="holding-field__label">板块数据刷新中</text>
      </view>

      <!-- 跳转指示箭头 -->
      <view class="holding-arrow">›</view>
    </view>
  </state-view>

</view>
