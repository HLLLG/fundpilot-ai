/* pages/holdings/holdings.wxss */
/* Holdings_Board 持仓看板页 — 应用 styles/tokens.wxss 设计 token */
/* Requirements: 5.3（展示字段）、1.1-1.4（设计系统 token） */

/* ── 页面布局 ────────────────────────────────── */
.holdings-page {
  min-height: 100vh;
  background: var(--bg);
}

/* ── 组合摘要卡片 ────────────────────────────── */
.summary-card {
  margin-bottom: var(--space-md);
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.summary-row--sub {
  margin-top: var(--space-xs);
  justify-content: flex-start;
}

.summary-item {
  display: flex;
  flex-direction: column;
}

.summary-item--right {
  align-items: flex-end;
}

.summary-label {
  font-size: var(--font-xs);
  color: var(--text-muted);
  margin-bottom: 4rpx;
}

.summary-value {
  font-family: var(--font-family-number);
  font-size: var(--font-xl);
  font-weight: 800;
  color: var(--text);
}

/* ── 更新时间（refreshed_at，Req 5.7） ─────────── */
.refreshed-at {
  display: flex;
  align-items: center;
  margin-top: var(--space-sm);
  flex-wrap: wrap;
  gap: var(--space-xs);
}

.refreshed-at__text {
  font-size: var(--font-xs);
  color: var(--text-muted);
}

.refreshed-at__text--toolbar {
  flex: 1;
  text-align: right;
}

.refreshed-at__stale {
  font-size: var(--font-xs);
  color: var(--warning);
}

/* ── 工具栏 ──────────────────────────────────── */
.holdings-toolbar {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  margin-bottom: var(--space-md);
}

/* ── 持仓卡片 ────────────────────────────────── */
.holding-card {
  margin-bottom: var(--space-sm);
  position: relative;
  /* 可点击区域指示 */
  cursor: pointer;
}

.holding-card:active {
  opacity: 0.85;
}

.holding-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-sm);
}

.holding-row--header {
  align-items: flex-start;
  margin-bottom: var(--space-sm);
}

.holding-row--sector {
  margin-top: var(--space-xs);
  margin-bottom: 0;
  gap: var(--space-sm);
}

.holding-name {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--text);
  flex: 1;
  margin-right: var(--space-sm);
  /* 超长名称截断 */
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.holding-code {
  font-size: var(--font-xs);
  flex-shrink: 0;
}

/* 字段：标签 + 值纵向布局 */
.holding-field {
  display: flex;
  flex-direction: column;
}

.holding-field--right {
  align-items: flex-end;
}

.holding-field__label {
  font-size: var(--font-xs);
  color: var(--text-muted);
  margin-bottom: 4rpx;
}

.holding-sector-name {
  max-width: 280rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 跳转箭头 */
.holding-arrow {
  position: absolute;
  right: var(--space-lg);
  top: 50%;
  transform: translateY(-50%);
  font-size: var(--font-lg);
  color: var(--text-muted);
  pointer-events: none;
}

/* ── 空态操作入口（Req 5.6） ─────────────────── */
.empty-actions {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  margin-top: var(--space-md);
  width: 100%;
  padding: 0 var(--space-md);
  box-sizing: border-box;
}

.empty-actions__btn {
  margin: 0;
}
