<!-- pages/report/report.wxml -->
<!-- 生成日报页（Daily_Report_Page）
     Req 13（生成日报）、Req 14（通过 chat-panel 追问）、Req 3.2（「更多」入口）。 -->

<scroll-view class="report-page" scroll-y enhanced>

  <!-- ── 配置区（Req 13.1）─────────────────────────────── -->
  <view class="card report-section" wx:if="{{jobPhase === 'idle' || jobPhase === 'failed'}}">
    <view class="report-section__title">生成配置</view>

    <!-- 投资预设 -->
    <view class="form-row">
      <text class="form-label">投资预设</text>
      <picker mode="selector" range="{{presets}}" range-key="label"
              value="{{presetIndex}}" bindchange="onPresetChange">
        <view class="form-picker">
          <text>{{presets[presetIndex].label}}</text>
          <text class="form-picker__arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 分析模式 -->
    <view class="form-row">
      <text class="form-label">分析模式</text>
      <view class="segmented">
        <view
          wx:for="{{modeOptions}}"
          wx:key="value"
          class="segmented__item {{modeIndex === index ? 'segmented__item--active' : ''}}"
          data-index="{{index}}"
          bindtap="onModeChange"
          data-value="{{index}}"
        >{{item.label}}</view>
      </view>
    </view>

    <!-- AI 角色设定 -->
    <view class="form-col">
      <text class="form-label">AI 角色设定</text>
      <textarea
        class="form-textarea"
        placeholder="输入 AI 角色提示词（可选）…"
        value="{{systemRolePrompt}}"
        bindinput="onPromptInput"
        maxlength="500"
        auto-height
      />
    </view>
  </view>

  <!-- ── 新闻预览（Req 13.2）──────────────────────────── -->
  <view class="card report-section" wx:if="{{jobPhase === 'idle' || jobPhase === 'failed'}}">
    <view class="report-section__header">
      <view class="report-section__title">主题要闻预览</view>
      <view class="btn btn-secondary btn--sm" bindtap="onPreviewNews">
        {{newsLoading ? '加载中…' : '获取预览'}}
      </view>
    </view>

    <view wx:if="{{newsError}}" class="report-error-text">{{newsError}}</view>

    <view wx:elif="{{newsPreview}}" class="news-preview">
      <view class="news-preview__meta">
        <text class="news-preview__label">时效：</text>
        <text class="news-preview__value">{{newsPreview.news_freshness || '—'}}</text>
      </view>
      <view class="news-preview__list">
        <view
          wx:for="{{newsPreview.headlines}}"
          wx:key="index"
          class="news-item"
        >
          <text class="news-item__dot">·</text>
          <text class="news-item__text">{{item}}</text>
        </view>
      </view>
    </view>
    <view wx:else class="report-placeholder-text">点击「获取预览」查看持仓相关主题要闻</view>
  </view>

  <!-- ── 生成按钮 / 重新生成按钮（Req 13.3, 13.10）───── -->
  <view class="report-actions" wx:if="{{jobPhase === 'idle' || jobPhase === 'failed'}}">
    <view class="btn btn-primary btn--lg report-actions__btn" bindtap="onGenerate">
      生成日报
    </view>
  </view>

  <!-- ── 轮询进度条（Req 13.4）───────────────────────── -->
  <view class="card report-section report-progress" wx:if="{{jobPhase === 'submitting' || jobPhase === 'polling'}}">
    <view class="report-progress__icon">⏳</view>
    <view class="report-progress__stage">
      {{jobPhase === 'submitting' ? '正在提交任务…' : (jobStageLabel || '分析中…')}}
    </view>
    <view class="report-progress__hint">日报生成约需 30–90 秒，请稍候</view>
    <view class="report-progress__bar">
      <view class="report-progress__fill"></view>
    </view>
  </view>

  <!-- ── 失败态（Req 13.10）──────────────────────────── -->
  <view class="card report-section report-fail" wx:if="{{jobPhase === 'failed'}}">
    <view class="report-fail__icon">✗</view>
    <text class="report-fail__msg">{{jobError || '日报生成失败，请重试'}}</text>
    <view class="btn btn-secondary btn--sm" bindtap="onReGenerate">重新生成</view>
  </view>

  <!-- ── 日报正文（Req 13.5, 13.6）──────────────────── -->
  <view class="card report-section" wx:if="{{jobPhase === 'completed' && reportMarkdown}}">
    <view class="report-section__title">日报正文</view>
    <md-view markdown="{{reportMarkdown}}" />
  </view>

  <!-- ── 操作按钮行（调仓/复盘/导出，Req 13.7–13.9）── -->
  <view class="report-btn-row" wx:if="{{jobPhase === 'completed' && report}}">
    <view class="btn btn-secondary btn--sm" bindtap="onShowRebalance">
      {{showRebalance ? '收起调仓' : '调仓示意'}}
    </view>
    <view class="btn btn-secondary btn--sm" bindtap="onShowOutcomes">
      {{showOutcomes ? '收起复盘' : '查看复盘'}}
    </view>
    <view class="btn btn-secondary btn--sm" bindtap="onExportMarkdown">
      导出 MD
    </view>
    <view class="btn btn-secondary btn--sm" bindtap="onToggleChat">
      {{showChat ? '收起追问' : 'AI 追问'}}
    </view>
  </view>

  <!-- ── 调仓示意内容（Req 13.7）───────────────────── -->
  <view class="card report-section" wx:if="{{showRebalance}}">
    <view class="report-section__title">调仓示意</view>
    <view wx:if="{{rebalanceLoading}}" class="report-placeholder-text">加载中…</view>
    <view wx:elif="{{rebalanceError}}" class="report-error-text">{{rebalanceError}}</view>
    <view wx:elif="{{rebalanceData}}">
      <view
        wx:for="{{rebalanceData.items}}"
        wx:key="fund_code"
        class="rebalance-item"
      >
        <text class="rebalance-item__name">{{item.fund_name || item.fund_code}}</text>
        <text class="rebalance-item__action">{{item.action}}</text>
        <text class="rebalance-item__amount">{{item.amount_display || ''}}</text>
      </view>
      <view wx:if="{{!rebalanceData.items || rebalanceData.items.length === 0}}" class="report-placeholder-text">暂无调仓建议</view>
    </view>
  </view>

  <!-- ── 复盘内容（Req 13.8）──────────────────────── -->
  <view class="card report-section" wx:if="{{showOutcomes}}">
    <view class="report-section__title">建议复盘</view>
    <view wx:if="{{outcomesLoading}}" class="report-placeholder-text">加载中…</view>
    <view wx:elif="{{outcomesError}}" class="report-error-text">{{outcomesError}}</view>
    <view wx:elif="{{outcomesData}}">
      <view class="outcomes-summary">
        <text>{{outcomesData.summary || '暂无复盘数据'}}</text>
      </view>
    </view>
  </view>

  <!-- ── AI 追问面板（Req 14，通过 chat-panel）──────── -->
  <view class="card report-section report-chat-section" wx:if="{{showChat && chatReportId}}">
    <view class="report-section__title">AI 追问</view>
    <chat-panel
      reportId="{{chatReportId}}"
      chatType="report"
      loading="{{false}}"
    />
  </view>

  <!-- ── 「更多」二级入口（Req 3.2）─────────────────── -->
  <view class="card report-section more-section">
    <text class="report-section__title">更多</text>
    <view class="more-grid">
      <view
        class="more-item"
        wx:for="{{moreItems}}"
        wx:key="key"
        data-target="{{item.key}}"
        bindtap="onMore"
      >
        <text class="more-item__label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- 底部留白 -->
  <view style="height: 40rpx;"></view>

</scroll-view>
