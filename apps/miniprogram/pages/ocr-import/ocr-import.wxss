/* pages/ocr-import/ocr-import.wxss */
/* OCR 截图录入页 — 依赖 styles/tokens.wxss 设计 token。 */
/* Requirements: 6.1–6.7，1.1–1.4（设计系统） */

/* ── 页面布局 ────────────────────────────────── */
.ocr-import-page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: var(--space-2xl);
}

/* ── 区块卡片 ────────────────────────────────── */
.section-card {
  margin-bottom: var(--space-md);
}

.section-title {
  margin-bottom: var(--space-xs);
}

.section-subtitle {
  color: var(--text-muted);
  font-size: var(--font-sm);
  margin-bottom: var(--space-md);
  line-height: 1.6;
}

/* ── 分段来源选择器 ───────────────────────────── */
.source-segmented {
  margin-bottom: var(--space-md);
  /* 3 项时文字稍小以适配 */
  font-size: var(--font-xs);
}

/* ── 选择截图按钮 ────────────────────────────── */
.choose-btn {
  margin-top: var(--space-sm);
}

/* ── 缩略图 ──────────────────────────────────── */
.thumb-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: var(--space-md);
}

.thumb-img {
  width: 100%;
  max-height: 480rpx;
  border-radius: var(--radius-md);
  background: var(--surface-muted);
}

.thumb-img--sm {
  width: 160rpx;
  height: 160rpx;
  flex-shrink: 0;
}

.thumb-header {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  padding: var(--space-md) var(--space-lg);
}

.reselect-btn {
  margin-left: auto;
}

/* ── 上传中/保存中 ───────────────────────────── */
.uploading-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-sm);
  padding: var(--space-xl) 0;
}

.uploading-text {
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.uploading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid var(--line-strong);
  border-top-color: var(--brand);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.uploading-spinner--sm {
  width: 28rpx;
  height: 28rpx;
  border-width: 3rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.saving-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-sm);
  padding: var(--space-sm) 0;
}

/* ── 告警面板（Req 6.6） ─────────────────────── */
.warning-card {
  border-color: var(--warning);
  margin-bottom: var(--space-md);
}

.warning-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.warning-badge {
  flex: 1;
}

.warning-toggle {
  font-size: var(--font-sm);
  color: var(--warning);
  padding-left: var(--space-sm);
  flex-shrink: 0;
}

.warning-list {
  margin-top: var(--space-sm);
  padding-top: var(--space-sm);
  border-top: 1rpx solid var(--warning-soft);
}

.warning-item {
  padding: var(--space-xs) 0;
}

.warning-text {
  font-size: var(--font-sm);
  color: var(--warning);
  line-height: 1.6;
}

/* ── 可编辑持仓行（Req 6.4） ─────────────────── */
.holding-edit-card {
  border: 1rpx solid var(--line);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  margin-top: var(--space-sm);
  background: var(--surface-muted);
}

.holding-edit-card:first-of-type {
  margin-top: var(--space-md);
}

.edit-row {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-sm);
  gap: var(--space-sm);
}

.edit-row--header {
  justify-content: space-between;
  margin-bottom: var(--space-xs);
}

.edit-index {
  font-size: var(--font-xs);
}

.delete-btn {
  color: var(--danger);
  font-size: var(--font-xs);
  height: 48rpx;
  padding: 0 var(--space-sm);
}

.edit-label {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  width: 200rpx;
  flex-shrink: 0;
}

.edit-input {
  flex: 1;
  height: 68rpx;
  border: 1rpx solid var(--line);
  border-radius: var(--radius-sm);
  background: var(--surface);
  padding: 0 var(--space-sm);
  font-size: var(--font-sm);
  color: var(--text);
  box-sizing: border-box;
}

.edit-input--num {
  font-family: var(--font-family-number);
}

/* ── 空结果提示 ──────────────────────────────── */
.empty-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-xl) 0;
  gap: var(--space-sm);
}

.empty-result__text {
  font-size: var(--font-sm);
  color: var(--text-muted);
  text-align: center;
  line-height: 1.6;
}

/* ── 错误提示（editing 态内嵌） ──────────────── */
.error-tip {
  background: var(--danger-soft);
  border-radius: var(--radius-sm);
  padding: var(--space-sm) var(--space-md);
  margin-bottom: var(--space-sm);
}

.error-tip__text {
  font-size: var(--font-sm);
  color: var(--danger);
  line-height: 1.5;
}

/* ── 确认按钮 ────────────────────────────────── */
.confirm-btn {
  margin-top: var(--space-md);
}

/* ── 错误态卡片（Req 4.2） ───────────────────── */
.error-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-2xl) var(--space-lg);
  gap: var(--space-md);
}

.error-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--danger-soft);
  color: var(--danger);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-xl);
  font-weight: 700;
}

.error-message {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.6;
}

.error-actions {
  display: flex;
  gap: var(--space-sm);
  flex-wrap: wrap;
  justify-content: center;
}
