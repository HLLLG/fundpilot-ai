<!-- pages/market/market.wxml -->
<!-- 市场页（Market_Page）：主题板块 / 大跌雷达（占位）/ 美股概览 -->
<!-- Requirements: 10.1–10.8, 11.1–11.6(占位), 12.1–12.6, 3.5 -->

<view class="market-page">

  <!-- ── 子视图 Tab Bar ───────────────────────────────────── -->
  <view class="sub-tab-bar">
    <view
      wx:for="{{subViews}}"
      wx:key="key"
      class="sub-tab-bar__item {{subView === item.key ? 'sub-tab-bar__item--active' : ''}}"
      data-key="{{item.key}}"
      bindtap="onSubViewTap"
    >{{item.label}}</view>
  </view>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- 子视图：主题板块（boards）                             -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <block wx:if="{{subView === 'boards'}}">

    <!-- 排序 Tab（change / inflow，Req 10.3） -->
    <view class="sort-bar">
      <view
        wx:for="{{sortOptions}}"
        wx:key="value"
        class="sort-bar__item {{sortIndex === index ? 'sort-bar__item--active' : ''}}"
        data-index="{{index}}"
        bindtap="onSortTap"
      >{{item.label}}</view>
    </view>

    <!-- 三态包裹（Req 4.1/4.2） -->
    <state-view
      loading="{{boardsLoading}}"
      error="{{boardsError}}"
      empty="{{boardsEmpty}}"
      emptyText="暂无板块数据"
      bind:retry="onBoardsRetry"
    >

      <!-- 板块卡片列表 -->
      <view wx:for="{{boardItems}}" wx:key="_idx" class="board-card card">

        <!-- ── 卡片头部：名称 + 标签行 ── -->
        <view class="board-card__header">
          <view class="board-card__title-row">
            <text class="board-card__name">{{item.sector_label}}</text>
            <!-- 板块类型标签：行业/概念/指数（Req 10.2） -->
            <view class="badge badge--muted board-card__kind-badge">{{item.kindLabel}}</view>
            <!-- 持仓标签（Req 10.5） -->
            <view wx:if="{{item.in_portfolio}}" class="badge badge--accent board-card__portfolio-badge">持仓</view>
          </view>

          <!-- 核心指标行：日涨跌幅 / 5日涨跌 / 主力净流入（Req 10.2） -->
          <view class="board-card__metrics">
            <view class="board-card__metric">
              <text class="board-card__metric-label">日涨跌</text>
              <num-text
                value="{{item.change_1d_percent}}"
                kind="percent"
                signed="{{true}}"
                class="board-card__metric-value"
              />
            </view>
            <view class="board-card__metric">
              <text class="board-card__metric-label">5日</text>
              <num-text
                value="{{item.change_5d_percent}}"
                kind="percent"
                signed="{{true}}"
                class="board-card__metric-value"
              />
            </view>
            <view class="board-card__metric">
              <text class="board-card__metric-label">主力净流入</text>
              <num-text
                value="{{item.main_force_net_yi}}"
                kind="money"
                signed="{{true}}"
                class="board-card__metric-value"
              />
            </view>
          </view>
        </view>

        <!-- ── 资金流四档展开/折叠 Toggle（Req 10.4） ── -->
        <view
          class="board-card__flow-toggle"
          data-idx="{{item._idx}}"
          bindtap="onToggleFlow"
        >
          <text class="board-card__flow-toggle-text">
            {{item.expandedFlow ? '收起资金流' : '展开资金流'}}
          </text>
          <text class="board-card__flow-arrow">{{item.expandedFlow ? '▲' : '▽'}}</text>
        </view>

        <!-- 资金流四档明细（展开时显示，Req 10.4） -->
        <view wx:if="{{item.expandedFlow && item.flow_tiers}}" class="board-card__flow-tiers">
          <view class="flow-tier">
            <text class="flow-tier__label">超大单</text>
            <num-text
              value="{{item.flow_tiers.super_large_net_yi}}"
              kind="money"
              signed="{{true}}"
              class="flow-tier__value"
            />
          </view>
          <view class="flow-tier">
            <text class="flow-tier__label">大单</text>
            <num-text
              value="{{item.flow_tiers.large_net_yi}}"
              kind="money"
              signed="{{true}}"
              class="flow-tier__value"
            />
          </view>
          <view class="flow-tier">
            <text class="flow-tier__label">中单</text>
            <num-text
              value="{{item.flow_tiers.medium_net_yi}}"
              kind="money"
              signed="{{true}}"
              class="flow-tier__value"
            />
          </view>
          <view class="flow-tier">
            <text class="flow-tier__label">小单</text>
            <num-text
              value="{{item.flow_tiers.small_net_yi}}"
              kind="money"
              signed="{{true}}"
              class="flow-tier__value"
            />
          </view>
        </view>

        <!-- ── 操作按钮行（Req 10.6 / 10.7） ── -->
        <view class="board-card__actions">
          <view
            class="btn btn-ghost btn--sm board-card__action-btn"
            data-sector="{{item.sector_label}}"
            bindtap="onViewDipFunds"
          >看大跌基金</view>
          <view
            class="btn btn-ghost btn--sm board-card__action-btn board-card__action-btn--accent"
            data-sector="{{item.sector_label}}"
            bindtap="onAddFocusSector"
          >加入关注方向</view>
        </view>

      </view>
      <!-- /board-card -->

      <!-- 数据更新时间（Req 10.8） -->
      <view wx:if="{{refreshedAt}}" class="refreshed-at">
        <text class="refreshed-at__text">数据更新于 {{refreshedAt}}</text>
      </view>

    </state-view>
  </block>
  <!-- /boards -->

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- 子视图：大跌反弹雷达（dip）—— 任务 5.4 实现           -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <block wx:if="{{subView === 'dip'}}">
    <state-view
      loading="{{dipLoading}}"
      error="{{dipError}}"
      empty="{{false}}"
      bind:retry="onDipRetry"
    >
      <view class="placeholder-sub">
        <text class="placeholder-sub__text">大跌反弹雷达将在任务 5.4 实现</text>
      </view>
    </state-view>
  </block>
  <!-- /dip -->

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- 子视图：美股概览（us）—— Req 12.1–12.6               -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <block wx:if="{{subView === 'us'}}">

    <!-- 三态包裹：加载/错误/空（Req 4.1/4.2）-->
    <state-view
      loading="{{usLoading && !usOverview}}"
      error="{{usError}}"
      empty="{{!usLoading && !usError && !usOverview}}"
      emptyText="暂无美股数据"
      bind:retry="onUsRetry"
    >

      <view wx:if="{{usOverview}}" class="us-overview">

        <!-- ── 美东时段条（Req 12.5）──────────────────────────────── -->
        <view class="us-session-bar">
          <view class="us-session-label-wrap">
            <text class="us-session-kind-badge">{{usSessionLabel}}</text>
            <text class="us-session-desc">美东时段</text>
          </view>
          <text wx:if="{{usUpdatedAt}}" class="us-updated-at">更新 {{usUpdatedAt}}</text>
        </view>

        <!-- ── 指数期货（纳指/标普/道指，Req 12.2）──────────────────── -->
        <view class="card us-section">
          <text class="us-section-title">美股指数期货</text>
          <view class="us-list">
            <view wx:for="{{usFutures}}" wx:key="symbol" class="us-quote-row">
              <text class="us-quote-name">{{item.name}}</text>
              <view class="us-quote-values">
                <!-- status==='unavailable' → 占位，不渲染数值（Req 12.6）-->
                <view wx:if="{{item.isUnavailable}}" class="us-unavailable">
                  <text class="us-unavailable-text">数据暂不可用</text>
                </view>
                <block wx:else>
                  <num-text
                    value="{{item.last_price}}"
                    kind="plain"
                    signed="{{false}}"
                    class="us-price"
                  />
                  <num-text
                    value="{{item.change_percent}}"
                    kind="percent"
                    signed="{{true}}"
                    class="us-change"
                  />
                </block>
              </view>
            </view>
          </view>
        </view>

        <!-- ── USD/CNY 汇率（Req 12.3）──────────────────────────────── -->
        <view wx:if="{{usUsdCny}}" class="card us-section">
          <text class="us-section-title">人民币汇率</text>
          <view class="us-list">
            <view class="us-quote-row">
              <text class="us-quote-name">{{usUsdCny.label}}</text>
              <view class="us-quote-values">
                <view wx:if="{{usUsdCny.isUnavailable}}" class="us-unavailable">
                  <text class="us-unavailable-text">数据暂不可用</text>
                </view>
                <block wx:else>
                  <num-text
                    value="{{usUsdCny.last_price}}"
                    kind="plain"
                    signed="{{false}}"
                    digits="{{4}}"
                    class="us-price"
                  />
                  <num-text
                    value="{{usUsdCny.change_percent}}"
                    kind="percent"
                    signed="{{true}}"
                    class="us-change"
                  />
                </block>
              </view>
            </view>
          </view>
        </view>

        <!-- ── QDII 盘前参考（Req 12.4，含非承诺免责标注）────────────── -->
        <view wx:if="{{usQdii.length > 0}}" class="card us-section">
          <view class="us-section-header">
            <text class="us-section-title">QDII 盘前参考</text>
            <!-- 非承诺性免责声明标注（Req 12.4）-->
            <view class="us-disclaimer-badge">
              <text class="us-disclaimer-text">非承诺预估</text>
            </view>
          </view>
          <view class="us-list">
            <view wx:for="{{usQdii}}" wx:key="{{index}}" class="us-quote-row">
              <text class="us-quote-name us-qdii-name">{{item.name}}</text>
              <view class="us-quote-values">
                <!-- status==='unavailable' → 占位（Req 12.6）-->
                <view wx:if="{{item.isUnavailable}}" class="us-unavailable">
                  <text class="us-unavailable-text">数据暂不可用</text>
                </view>
                <block wx:else>
                  <num-text
                    value="{{item.change_percent}}"
                    kind="percent"
                    signed="{{true}}"
                    class="us-change"
                  />
                </block>
              </view>
            </view>
          </view>
        </view>

        <!-- ── 手动刷新按钮 ────────────────────────────────────────────── -->
        <view class="us-refresh-row">
          <view class="btn btn-secondary btn--sm" bindtap="onUsRefresh">刷新</view>
        </view>

      </view>
      <!-- /us-overview -->

    </state-view>
  </block>
  <!-- /us -->

</view>
