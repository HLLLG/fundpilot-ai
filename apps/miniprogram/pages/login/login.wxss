.page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #eff6ff 0%, #f8fafc 100%);
  padding: 48rpx;
}

.card {
  width: 100%;
  background: #fff;
  border-radius: 32rpx;
  padding: 64rpx 48rpx;
  box-shadow: 0 24rpx 60rpx rgba(15, 23, 42, 0.08);
  text-align: center;
}

.logo {
  display: block;
  width: 144rpx;
  height: 144rpx;
  margin: 0 auto 24rpx;
  border-radius: 32rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: #0f172a;
}

.subtitle {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #64748b;
}

.btn {
  margin-top: 48rpx;
  background: linear-gradient(90deg, #2356e0, #173fb0);
  color: #fff;
  border-radius: 24rpx;
}

.error {
  display: block;
  margin-top: 24rpx;
  color: #dc2626;
  font-size: 26rpx;
}
