/* pages/settings/settings.wxss */
/* 账号设置页样式 · 使用 styles/tokens.wxss 中定义的设计 token */

.settings-page {
  min-height: 100vh;
  background: var(--bg);
}

/* ── 页面头部 ───────────────────────────────── */
.settings-header {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  margin-bottom: var(--space-md);
}

.settings-header__title {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text);
  line-height: 1.2;
}

.settings-header__subtitle {
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

/* ── 账号信息卡片 ───────────────────────────── */
.settings-account {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.settings-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-md);
}

.settings-row__label {
  font-size: var(--font-base);
  color: var(--text-secondary);
  flex-shrink: 0;
}

.settings-row__value {
  font-size: var(--font-base);
  color: var(--text);
  text-align: right;
  word-break: break-all;
}

/* ── 关联邮箱卡片 ───────────────────────────── */
.settings-link {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.settings-field {
  padding: var(--space-sm) var(--space-md);
  background: var(--surface-muted);
  border: 2rpx solid var(--line);
  border-radius: var(--radius-md);
  font-size: var(--font-base);
  color: var(--text);
}

.settings-link__error {
  font-size: var(--font-sm);
  color: var(--danger);
  line-height: 1.5;
}

.settings-link__submit {
  margin-top: var(--space-xs);
}
