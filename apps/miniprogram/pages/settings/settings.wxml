<!-- pages/settings/settings.wxml -->
<!-- 账号设置页（Settings_Page） -->
<!-- Requirements: 21.1, 21.2, 21.3, 21.4 -->

<view class="settings-page u-page">

  <view class="settings-header">
    <text class="settings-header__title">账号设置</text>
    <text class="settings-header__subtitle">管理账号与微信、邮箱绑定</text>
  </view>

  <!-- ── 三态包裹（Req 4.1/4.2）── -->
  <state-view
    loading="{{loading}}"
    error="{{error}}"
    bind:retry="onRetry"
  >

    <!-- ── 账号信息 + 微信绑定状态（Req 21.1）── -->
    <view class="card settings-account">
      <text class="card__title">当前账号</text>

      <view class="settings-row">
        <text class="settings-row__label">昵称</text>
        <text class="settings-row__value">{{user.username || '—'}}</text>
      </view>

      <view class="settings-row">
        <text class="settings-row__label">账号</text>
        <text class="settings-row__value">{{accountDisplay || '—'}}</text>
      </view>

      <view class="settings-row">
        <text class="settings-row__label">微信绑定</text>
        <view class="badge {{wechatBound ? 'badge--accent' : 'badge--muted'}}">
          {{wechatStatusText}}
        </view>
      </view>
    </view>

    <!-- ── 关联已有邮箱账号（仅微信占位账号可见，Req 21.2）── -->
    <view wx:if="{{isPlaceholder}}" class="card settings-link">
      <text class="card__title">关联已有邮箱账号</text>
      <text class="card__subtitle">
        输入你在 Web 端注册的邮箱与密码，关联后即可在小程序看到相同持仓
      </text>

      <input
        class="settings-field"
        type="text"
        placeholder="邮箱"
        value="{{account}}"
        bindinput="onAccountInput"
      />
      <input
        class="settings-field"
        password="{{true}}"
        placeholder="密码"
        value="{{password}}"
        bindinput="onPasswordInput"
      />

      <!-- 失败时展示后端错误文案，输入保留（Req 21.4）-->
      <text wx:if="{{linkError}}" class="settings-link__error">{{linkError}}</text>

      <view
        class="btn btn-primary btn--block settings-link__submit {{linking ? 'btn--disabled' : ''}}"
        hover-class="btn--press"
        bindtap="onLinkEmail"
      >
        <text>{{linking ? '关联中…' : '关联账号'}}</text>
      </view>
    </view>

  </state-view>

</view>
