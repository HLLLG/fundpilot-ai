<!-- pages/briefing/briefing.wxml -->
<!-- 简报首页（Briefing_Page，Req 17）：
     组合 KPI 摘要 + 板块脉搏摘要 + 最新日报决策卡摘要 + 内联非流式追问。 -->

<view class="briefing-page">

  <!-- ── 组合 KPI 摘要（Req 17.2）──────────────────────────── -->
  <view class="briefing-page__section-title">
    <text class="briefing-page__title-text">组合概况</text>
    <text wx:if="{{refreshedAt}}" class="briefing-page__refreshed">更新于 {{refreshedAt}}</text>
  </view>

  <state-view
    loading="{{loading}}"
    error="{{error}}"
    bind:retry="onHoldingsRetry"
  >
    <view class="card briefing-page__kpi-card">
      <view class="briefing-page__kpi-row">
        <view class="briefing-page__kpi-item">
          <text class="briefing-page__kpi-label">总资产</text>
          <num-text
            class="briefing-page__kpi-value"
            value="{{kpi.totalAssets}}"
            kind="money"
            signed="{{false}}"
          />
        </view>
        <view class="briefing-page__kpi-item">
          <text class="briefing-page__kpi-label">当日收益</text>
          <num-text
            class="briefing-page__kpi-value"
            value="{{kpi.dailyProfit}}"
            kind="money"
            signed="{{true}}"
          />
        </view>
        <view class="briefing-page__kpi-item">
          <text class="briefing-page__kpi-label">持有收益</text>
          <num-text
            class="briefing-page__kpi-value"
            value="{{kpi.holdingProfit}}"
            kind="money"
            signed="{{true}}"
          />
        </view>
      </view>
      <view wx:if="{{!hasHoldings}}" class="briefing-page__kpi-empty">
        <text class="u-muted">暂无持仓数据，可前往持仓页录入或关联账号。</text>
      </view>
    </view>
  </state-view>

  <!-- ── 板块脉搏摘要（Req 17.3）──────────────────────────── -->
  <view class="briefing-page__section-title">
    <text class="briefing-page__title-text">板块脉搏</text>
  </view>

  <state-view
    loading="{{sectorLoading && sectorPulse.length === 0}}"
    error="{{sectorError && sectorPulse.length === 0 ? sectorError : ''}}"
    empty="{{!sectorLoading && !sectorError && sectorPulse.length === 0}}"
    emptyText="暂无板块行情数据"
    bind:retry="onSectorRetry"
  >
    <view class="card briefing-page__sector-card">
      <view
        wx:for="{{sectorPulse}}"
        wx:key="sector_label"
        class="briefing-page__sector-item"
      >
        <view class="briefing-page__sector-info">
          <text class="briefing-page__sector-name">{{item.sector_label}}</text>
          <view class="briefing-page__sector-meta">
            <text wx:if="{{item.kindLabel}}" class="badge briefing-page__sector-kind">{{item.kindLabel}}</text>
            <text wx:if="{{item.in_portfolio}}" class="badge briefing-page__sector-hold">持仓</text>
            <text wx:if="{{item.consecutive_up_days}}" class="briefing-page__sector-streak">连涨{{item.consecutive_up_days}}天</text>
          </view>
        </view>
        <num-text
          class="briefing-page__sector-change"
          value="{{item.change_1d_percent}}"
          kind="percent"
        />
      </view>
    </view>
  </state-view>

  <!-- ── 最新日报决策卡摘要（Req 17.4）────────────────────── -->
  <view class="briefing-page__section-title">
    <text class="briefing-page__title-text">最新日报</text>
  </view>

  <view wx:if="{{latestReport}}" class="card briefing-page__report-card">
    <view class="briefing-page__report-head">
      <text class="briefing-page__report-title">{{latestReport.title}}</text>
      <text wx:if="{{latestReport.createdAt}}" class="briefing-page__report-time">{{latestReport.createdAt}}</text>
    </view>

    <view class="briefing-page__report-tags">
      <text
        wx:if="{{latestReport.riskLevelLabel}}"
        class="badge briefing-page__risk-badge briefing-page__risk-badge--{{latestReport.riskLevel}}"
      >{{latestReport.riskLevelLabel}}</text>
      <text wx:if="{{latestReport.suggestedActionLabel}}" class="badge briefing-page__action-badge">{{latestReport.suggestedActionLabel}}</text>
      <view wx:if="{{latestReport.weightedReturnPercent !== null}}" class="briefing-page__report-return">
        <text class="briefing-page__report-return-label">加权收益</text>
        <num-text value="{{latestReport.weightedReturnPercent}}" kind="percent" />
      </view>
    </view>

    <text wx:if="{{latestReport.summary}}" class="briefing-page__report-summary">{{latestReport.summary}}</text>

    <view wx:if="{{latestReport.recommendations.length > 0}}" class="briefing-page__report-recs">
      <view
        wx:for="{{latestReport.recommendations}}"
        wx:for-item="rec"
        wx:key="index"
        class="briefing-page__report-rec"
      >
        <text class="briefing-page__report-rec-dot">•</text>
        <text class="briefing-page__report-rec-text">{{rec}}</text>
      </view>
    </view>

    <view class="briefing-page__report-actions">
      <view class="btn btn-secondary btn--sm" bindtap="onOpenReport">查看完整日报</view>
      <view class="btn btn-primary btn--sm" bindtap="onToggleChat">
        {{showChat ? '收起追问' : '内联追问'}}
      </view>
    </view>
  </view>

  <view wx:elif="{{!reportsLoading}}" class="card briefing-page__report-empty">
    <text class="u-muted">暂无日报，前往「生成日报」创建你的第一份。</text>
    <view class="btn btn-secondary btn--sm briefing-page__report-empty-btn" bindtap="onOpenReport">生成日报</view>
  </view>

  <!-- ── 内联非流式追问（Req 17.5，复用 chat-panel / BC1）──── -->
  <view wx:if="{{showChat && chatReportId}}" class="card briefing-page__chat-card">
    <chat-panel reportId="{{chatReportId}}" chatType="report" />
  </view>

</view>
