/* pages/fund-edit/fund-edit.wxss */
/* 手动新增/编辑持仓页 — 依赖 styles/tokens.wxss 设计 token。 */
/* Requirements: 7.1–7.5, 1.1–1.4（设计系统） */

/* ── 页面布局 ────────────────────────────────── */
.fund-edit-page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: var(--space-2xl);
}

/* ── 区块卡片 ────────────────────────────────── */
.section-card {
  margin-bottom: var(--space-md);
}

.section-title {
  margin-bottom: var(--space-xs);
}

.section-subtitle {
  color: var(--text-muted);
  font-size: var(--font-sm);
  margin-bottom: var(--space-md);
  line-height: 1.6;
}

/* ── 搜索输入框（Req 7.1） ───────────────────── */
.search-input-wrap {
  position: relative;
  display: flex;
  align-items: center;
}

.search-input {
  flex: 1;
  height: 72rpx;
  border: 1rpx solid var(--line);
  border-radius: var(--radius-md);
  background: var(--surface-muted);
  padding: 0 var(--space-md);
  padding-right: 64rpx;  /* 为 spinner 留空间 */
  font-size: var(--font-base);
  color: var(--text);
  box-sizing: border-box;
}

.search-spinner {
  position: absolute;
  right: var(--space-md);
  width: 36rpx;
  height: 36rpx;
  border: 3rpx solid var(--line-strong);
  border-top-color: var(--brand);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ── 搜索下拉（Req 7.1 候选展示）───────────────── */
.search-dropdown {
  margin-top: var(--space-sm);
  background: var(--surface);
  border: 1rpx solid var(--line);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-md);
}

.search-item {
  display: flex;
  align-items: center;
  padding: var(--space-sm) var(--space-md);
  border-bottom: 1rpx solid var(--line);
  gap: var(--space-sm);
}

.search-item:last-child {
  border-bottom: none;
}

.search-item--hover {
  background: var(--brand-soft);
}

.search-item__code {
  flex-shrink: 0;
  font-family: var(--font-family-number);
  font-size: var(--font-xs);
  min-width: 120rpx;
}

.search-item__name {
  flex: 1;
  font-size: var(--font-sm);
  color: var(--text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.search-item__arrow {
  color: var(--text-muted);
  font-size: var(--font-lg);
  flex-shrink: 0;
}

.search-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-lg);
}

.search-empty__text {
  font-size: var(--font-sm);
  color: var(--text-muted);
}

/* ── 表单区域 ────────────────────────────────── */
.form-card {
  /* form-card 下各 form-row 之间稍留空 */
}

.form-row {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-md);
  gap: var(--space-sm);
}

.form-row:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  width: 220rpx;
  flex-shrink: 0;
  line-height: 1.4;
}

.form-input {
  flex: 1;
  height: 72rpx;
  border: 1rpx solid var(--line);
  border-radius: var(--radius-sm);
  background: var(--surface-muted);
  padding: 0 var(--space-sm);
  font-size: var(--font-base);
  color: var(--text);
  box-sizing: border-box;
}

/* 代码无法解析时高亮边框（Req 7.5） */
.form-input--error {
  border-color: var(--danger);
  background: var(--danger-soft);
}

.form-input--num {
  font-family: var(--font-family-number);
}

/* ── 错误横幅（Req 7.5）──────────────────────── */
.error-banner {
  display: flex;
  align-items: flex-start;
  background: var(--danger-soft);
  border: 1rpx solid var(--danger);
  border-radius: var(--radius-md);
  padding: var(--space-sm) var(--space-md);
  margin-bottom: var(--space-md);
  gap: var(--space-sm);
}

.error-banner__icon {
  flex-shrink: 0;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--danger);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-xs);
  font-weight: 700;
}

.error-banner__text {
  flex: 1;
  font-size: var(--font-sm);
  color: var(--danger);
  line-height: 1.6;
}

.error-banner__dismiss {
  flex-shrink: 0;
  font-size: var(--font-sm);
  color: var(--danger);
  font-weight: 600;
  padding-left: var(--space-sm);
}

/* ── 保存中指示 ───────────────────────────────── */
.saving-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-sm);
  padding: var(--space-sm) 0;
  margin-bottom: var(--space-sm);
}

.saving-spinner {
  width: 36rpx;
  height: 36rpx;
  border: 3rpx solid var(--line-strong);
  border-top-color: var(--brand);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.saving-text {
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

/* ── 保存按钮 ────────────────────────────────── */
.save-btn {
  margin-top: var(--space-md);
}
