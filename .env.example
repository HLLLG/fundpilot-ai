# FundPilot AI — copy to .env and set secrets in the first block

# Secrets & paths
FUND_AI_JWT_SECRET=fundpilot-dev-jwt-secret-change-me-32chars
# FUND_AI_DATABASE_URL=mysql://user:pass@host:3306/fundpilot
# FUND_AI_CLOUDBASE_ENV_ID=
# FUND_AI_CLOUDBASE_CUSTOM_LOGIN_KEY=./secrets/cloudbase-custom-login.json
# FUND_AI_CLOUDBASE_AUTH_DEV_MODE=false
FUND_AI_DEEPSEEK_API_KEY=
# FUND_AI_DB_PATH=
# FUND_AI_UPLOAD_DIR=
FUND_AI_DB_AUTO_IMPORT_PATH=
# Optional VPS relay: http://host:8787/boards (also serves /kline/daily for backtest)
FUND_AI_SECTOR_QUOTES_RELAY_URL=
FUND_AI_SECTOR_QUOTES_RELAY_TOKEN=
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# App defaults
FUND_AI_JWT_ACCESS_EXPIRE_MINUTES=43200

FUND_AI_DEEPSEEK_BASE_URL=https://api.deepseek.com
FUND_AI_DEEPSEEK_MODEL=deepseek-v4-pro
FUND_AI_DEEPSEEK_MODEL_FAST=deepseek-v4-flash
FUND_AI_DEEPSEEK_TIMEOUT_SECONDS=300
FUND_AI_DEEPSEEK_MAX_TOKENS=384000
FUND_AI_DEEPSEEK_MAX_TOKENS_REPORT=384000

FUND_AI_NEWS_ENABLED=true
FUND_AI_NEWS_MAX_TOPICS=5
FUND_AI_NEWS_PER_TOPIC=5
FUND_AI_NEWS_TOOL_MAX_ROUNDS=3
FUND_AI_NEWS_SOURCES=eastmoney,cls,announcement,macro
FUND_AI_NEWS_SUMMARIZE=true
FUND_AI_NEWS_SUMMARIZE_MODEL=
FUND_AI_NEWS_SUMMARIZE_MAX_POINTS=5
FUND_AI_NEWS_SUMMARIZE_TIMEOUT_SECONDS=60
FUND_AI_NEWS_MACRO_TOPIC=上证指数
FUND_AI_NEWS_REQUIRE_TODAY_FOR_ADD=true

FUND_AI_TACTICAL_PROMPT_TUNING_ENABLED=true
FUND_AI_TACTICAL_PROMPT_TUNING_LOOKBACK_REPORTS=30
FUND_AI_SECTOR_SIGNAL_BACKTEST_ENABLED=true
FUND_AI_SECTOR_SIGNAL_BACKTEST_DAYS=120
FUND_AI_SECTOR_SIGNAL_BACKTEST_MIN_TRIGGERS=10

FUND_AI_NAV_TREND_DAYS=66
FUND_AI_NAV_TREND_RECENT_SAMPLE=8

FUND_AI_SECTOR_QUOTES_ENABLED=true
FUND_AI_SECTOR_QUOTES_TTL_SECONDS=60
FUND_AI_SECTOR_QUOTES_RESPECT_MANUAL=false
FUND_AI_SECTOR_QUOTES_DISCREPANCY_WARN=0.5
FUND_AI_SECTOR_QUOTES_AUTO_INTERVAL_SECONDS=300
FUND_AI_SECTOR_QUOTES_RELAY_TIMEOUT_SECONDS=2.5
FUND_AI_SECTOR_QUOTES_BROWSER_ENABLED=false
FUND_AI_SECTOR_QUOTES_BROWSER_COMMAND=node scripts/sector-quote-browser-command.mjs
FUND_AI_SECTOR_QUOTES_BROWSER_TIMEOUT_SECONDS=20
FUND_AI_SECTOR_INTRADAY_BROWSER_COMMAND=node scripts/sector-intraday-browser-command.mjs

# 主题板块（市场 Tab）后台刷新：daemon 线程时段感知，前台只读缓存
FUND_AI_THEME_BOARD_REFRESH_ENABLED=true
FUND_AI_THEME_BOARD_REFRESH_INTERVAL_SECONDS=900
FUND_AI_THEME_BOARD_REFRESH_IDLE_INTERVAL_SECONDS=3600

FUND_AI_CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# 本地开发：远程 MySQL 不可达时自动回退 SQLite（生产环境请设为 false）
FUND_AI_DB_FALLBACK_SQLITE=true

FUND_AI_OCR_PRELOAD=true
FUND_AI_OCR_USE_MOBILE_MODELS=true
FUND_AI_OCR_MAX_IMAGE_SIDE=1280
