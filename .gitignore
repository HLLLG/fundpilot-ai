.env
.env.production
.idea/
.agents/
skills-lock.json
.venv/
.worktrees/
node_modules/
.next/
artifacts/
dist/
build/
__pycache__/
.pytest_cache/
.tmp/
*.pyc
*.tsbuildinfo
data/*
!data/.gitkeep
uploads/*
!uploads/.gitkeep
!uploads/inbox/
uploads/inbox/*
!uploads/inbox/.gitkeep
apps/api/.venv/
apps/api/.uvicorn-*.log
# var/ 下的内容默认是生成物/缓存，不入库；但 factor_ic/ 这一层目录本身要保留
# 一个 .gitkeep 占位（见该文件注释），保证 Dockerfile 的 COPY 不会因目录在一次
# 干净 checkout 里完全不存在而报错构建失败。
apps/api/var/*
!apps/api/var/factor_ic
apps/api/var/factor_ic/*
!apps/api/var/factor_ic/.gitkeep
debug-*.log
.tmp-*.html
apps/web/.next/
apps/web/out/
apps/web/next-env.d.ts
apps/web/node_modules/
apps/web/test-results/
CLEANUP_REPORT.md
COMMIT_EDITMSG_TMP

# 截图验收输出（构建产物，不入库）
apps/web/verify-shots/
